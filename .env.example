# Gravio — Environment Variables
# Copy this file to .env and fill in values for local development.
# Never commit .env to git.

# Required: 32+ character random string used to sign session cookies.
# Generate one: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=your-session-secret-here

# HTTP port (default: 3000)
# PORT=3000

# Set to "production" to enable Secure cookie flag and canonical redirect
# NODE_ENV=production

# ── Google SSO (optional) ─────────────────────────────────────────────────────
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=
# GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3000/auth/sso/google/callback

# ── LemonSqueezy billing (optional) ──────────────────────────────────────────
# LEMON_API_KEY=
# LEMON_STORE_ID=
# LEMON_TEAM_VARIANT_ID=
# LEMON_WEBHOOK_SECRET=
